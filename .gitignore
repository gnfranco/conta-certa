# ----------------------------
# Sistema operacional
# ----------------------------
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ----------------------------
# Editores / IDEs
# ----------------------------
.vscode/*
!.vscode/
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
tempCodeRunnerFile.py

# ----------------------------
# Python: bytecode / cache
# ----------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# ----------------------------
# Ambientes virtuais
# ----------------------------
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
__pypackages__/

# ----------------------------
# Variáveis locais / segredos
# ----------------------------
.env
.env.*
!.env.example
.streamlit/secrets.toml

# Se um dia houver config local com segredos, use:
# .streamlit/config.toml
# Mas mantenha config.toml versionado se ele só tiver tema/layout.

# ----------------------------
# Banco local do Conta Certa
# ----------------------------
# O app usa SQLite local em data/cobrancas.db.
# Não versionar dados reais, dívidas, pagamentos ou relatórios pessoais.
data/*
!data/.gitkeep

*.db
*.sqlite
*.sqlite3
*.db-journal
*.sqlite-journal
*.sqlite3-journal
*.db-wal
*.sqlite-wal
*.sqlite3-wal
*.db-shm
*.sqlite-shm
*.sqlite3-shm

# ----------------------------
# Relatórios/exportações gerados pelo app
# ----------------------------
exports/
export/
relatorios/
reports/
output/
outputs/

# Evita subir demonstrativos pessoais gerados localmente.
*.pdf
*.xlsx

# Permite manter exemplos públicos/documentação se você criar.
!docs/**/*.pdf
!docs/**/*.xlsx
!examples/**/*.pdf
!examples/**/*.xlsx
!samples/**/*.pdf
!samples/**/*.xlsx

# ----------------------------
# Logs e arquivos temporários
# ----------------------------
*.log
logs/
*.tmp
*.temp
.cache/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.pyre/
.pytype/
.dmypy.json
dmypy.json

